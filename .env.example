# Core server
PORT=3737
HOST=0.0.0.0
VOTES_DB_PATH=./votes.sqlite

# Anonymous voter cookie
VOTER_COOKIE_NAME=biz_voter
VOTER_COOKIE_MAX_AGE_S=31536000
VOTER_COOKIE_SECURE=0

# Vote write throttling
VOTE_RATE_LIMIT_WINDOW_MS=60000
VOTE_RATE_LIMIT_MAX_WRITES=90

# Admin moderation login
# Leave ADMIN_USERNAME/ADMIN_PASSWORD empty to disable admin login.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_COOKIE_NAME=biz_admin
ADMIN_SESSION_TTL_S=43200
ADMIN_COOKIE_SECURE=0
ADMIN_SESSION_CLEANUP_MS=600000

# Visitor submissions
SUBMISSION_DAILY_LIMIT=1
SUBMISSION_WINDOW_MS=86400000
SUBMISSION_TITLE_MAX=140
SUBMISSION_NICK_MAX=40
SUBMISSION_DESC_MAX=1600
SUBMISSION_CONTACT_MAX=120
